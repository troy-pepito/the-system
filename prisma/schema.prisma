// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DungeonRun {
  id         Int                  @id @default(autoincrement())
  userId     String
  dungeonId  String
  startDate  DateTime?            @db.Date
  active     Boolean              @default(true)
  endReason  String?
  events     DungeonEvent[]
  checkIns   DungeonDayCheckIn[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([userId, dungeonId, active])
}

model DungeonDayCheckIn {
  id          Int        @id @default(autoincrement())
  runId       Int
  run         DungeonRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId      String
  dungeonId   String
  date        DateTime   @db.Date
  state       String     // "cleared" | "relapsed"
  count       Int        @default(1)
  confirmedAt DateTime   @default(now())

  // A check-in is a fact about (user, dungeon, calendar day), not
  // about a specific run. Scoping the unique here closes the
  // exit-and-re-clear-the-same-day XP exploit at the schema level
  // and lets confirmDay upsert across runs.
  @@unique([userId, dungeonId, date])
}

model DungeonEvent {
  id        Int          @id @default(autoincrement())
  runId     Int
  run       DungeonRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  type      String
  date      DateTime     @db.Date
  value     Float?
  note      String?
  isPublic  Boolean      @default(false)
  createdAt DateTime     @default(now())
  reactions Reaction[]
}

model Reaction {
  id        Int          @id @default(autoincrement())
  eventId   Int
  event     DungeonEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime     @default(now())

  // One row per (event, user, emoji) — clicking the same emoji twice
  // toggles the reaction off rather than stacking.
  @@unique([eventId, userId, emoji])
  @@index([eventId])
}

model QuestCompletion {
  id        Int      @id @default(autoincrement())
  userId    String
  questId   String
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, questId, date])
}

model Achievement {
  id             Int      @id @default(autoincrement())
  userId         String
  achievementId  String
  unlockedAt     DateTime @default(now())

  @@unique([userId, achievementId])
}

model EmailSent {
  id     Int      @id @default(autoincrement())
  userId String
  type   String
  sentAt DateTime @default(now())

  @@index([userId, type, sentAt])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  timezone  String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Friendship {
  id          Int      @id @default(autoincrement())
  requesterId String
  addresseeId String
  status      String   // "pending" | "accepted"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
}